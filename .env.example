# AutoDrive — root-level docker-compose variables
#
# Copy to `.env` and tweak as needed: `cp .env.example .env`
# docker-compose automatically reads `.env` and substitutes ${VAR} values.

# Shared JWT secret. Must be identical across auth, cars, and reviews so
# tokens issued by auth validate everywhere.
JWT_SECRET=autodrive-change-this-secret-in-production
