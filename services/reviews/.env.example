# AutoDrive — Reviews service

PORT=4002

# JWT secret shared with the auth service.
JWT_SECRET=autodrive-dev-secret-change-in-prod

# Sentiment endpoint (Samarth's service). POST { text } → { label, score }.
# Locally we use the Azure Functions dev URL; in prod this points to the
# deployed Function App.
SENTIMENT_API_URL=https://autodrive-ml-samarth.azurewebsites.net/sentiment
