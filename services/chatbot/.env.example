# AutoDrive — Chatbot service (Ashad)

# Mode: "local" (Ollama, no API keys) or "azure" (Azure OpenAI)
MODE=local

# Azure OpenAI (only needed if MODE=azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Cars service — so the chatbot can ground answers on live inventory
CARS_API_URL=http://cars:8001

# Server
PORT=8002
