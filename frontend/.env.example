# AutoDrive — Frontend (Next.js)
#
# NEXT_PUBLIC_ variables are inlined at build time and exposed to the browser,
# so they must be the URLs a browser can reach — NOT docker-internal hostnames.
# For local dev this means localhost; in production each points at an
# Ingress/API Gateway hostname.

NEXT_PUBLIC_CARS_API_URL=http://localhost:8001
NEXT_PUBLIC_AUTH_API_URL=http://localhost:4001
NEXT_PUBLIC_REVIEWS_API_URL=http://localhost:4002
NEXT_PUBLIC_CHATBOT_API_URL=http://localhost:8002
NEXT_PUBLIC_ML_PRICE_API_URL=https://autodrive-ml-samarth.azurewebsites.net
